# SeaForge Configuration
# Copy to .env and adjust as needed

# Server
SEAFORGE_HOST=0.0.0.0
SEAFORGE_PORT=5000
SEAFORGE_DEBUG=false

# Database (SQLite, stored in data/ directory)
SEAFORGE_DB_PATH=data/seaforge.db

# AIS (optional — sign up free at https://aisstream.io)
AISSTREAM_API_KEY=

# Timezone (for rest hour calculations)
SEAFORGE_TIMEZONE=UTC

# Secret key (change this! used for session cookies)
SEAFORGE_SECRET_KEY=change-me-before-deploying
